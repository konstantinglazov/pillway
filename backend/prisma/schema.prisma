generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BookingStatus {
  pending
  confirmed
  cancelled
}

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String    @unique
  passwordHash String    @map("password_hash")
  fullName     String?   @map("full_name")
  createdAt    DateTime  @default(now()) @map("created_at")

  bookings     Booking[]

  @@map("users")
}

model Pharmacy {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  formattedAddress String   @map("formatted_address")
  lat              Float
  lng              Float
  placeId          String   @unique @map("place_id")
  createdAt        DateTime @default(now()) @map("created_at")

  bookings         Booking[]

  @@map("pharmacies")
}

model Booking {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String        @map("user_id") @db.Uuid
  pharmacyId         String        @map("pharmacy_id") @db.Uuid
  serviceType        String        @map("service_type")
  additionalServices String[]      @map("additional_services")
  prescriptionNotes  String?       @map("prescription_notes")
  status             BookingStatus @default(pending)
  createdAt          DateTime      @default(now()) @map("created_at")

  user     User     @relation(fields: [userId],     references: [id], onDelete: Cascade)
  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id])

  @@index([userId])
  @@map("bookings")
}
