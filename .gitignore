# Environment files — NEVER commit real secrets
.env
*.env.local
*.env.production
*.env.development.local

# Frontend env file with real keys (generated into environment.ts at build time)
frontend/.env

# Generated environment file — contains real keys, never commit
frontend/src/environments/environment.ts

# Dependencies
node_modules/
**/node_modules/

# Build output
dist/
**/dist/
out-tsc/

# Angular cache
.angular/

# TypeScript
*.js.map
*.d.ts.map

# IDE / OS
.DS_Store
.vscode/settings.json
*.swp
*.swo
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test coverage
coverage/
